# EVCHAIN Backend Configuration
# Copy this file to .env and fill in your values before starting the server

# Server
PORT=3000
NODE_ENV=production

# REQUIRED: Change this to a long random string before deploying
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend origin allowed by CORS (no trailing slash)
FRONTEND_URL=https://gutblast62-dev.github.io

# Optional: override default database path (default: ./evchain.db)
# DB_PATH=/var/data/evchain.db
